$TTL    604800
@   IN  SOA homelab.local. root.homelab.local. (
              2         ; Serial
         604800         ; Refresh
          86400         ; Retry
        2419200         ; Expire
         604800 )       ; Negative Cache TTL

@       IN  NS      ns.homelab.local.
ns      IN  A       192.168.1.6
srv     IN  A       192.168.1.6
